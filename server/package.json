{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=local nodemon --exec ts-node src/server.ts",
    "start:docker": "cross-env NODE_ENV=development nodemon --exec ts-node src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",

    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",

    "docker:dev": "docker-compose --env-file .env.development -f docker-compose.dev.yml up --build",
    "docker:prod": "docker-compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "docker:down": "docker-compose --env-file .env.development -f docker-compose.dev.yml down -v",

    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/graphql": "^14.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "prisma-zod-generator": "^2.1.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}